{
  "manufacturer": "Ishan Karar",
  "keyboard_name": "k_macropad_6sw_1rte",
  "maintainer": "kurkuregamerz",

  "bootloader": "rp2040",
  "processor": "RP2040",

  "features": {
    "bootmagic": true,
    "extrakey": true,
    "mousekey": true,
    "nkro": true
  },
  "diode_direction": "COL2ROW",

  "matrix_pins": {
    "rows": ["GP1", "GP2"],
    "cols": ["GP3", "GP4", "GP5"]
  },

  "encoder": {
    "rotary": [
      {
        "pin_a": "GP9",
        "pin_b": "GP8"
      }
    ]
  },

  "usb": {
    "vid": "0xFEED",
    "pid": "0x0001",
    "device_version": "1.0.0"
  },

  "layouts": {
    "LAYOUT": {
      "layout": [
        { "matrix": [0, 0], "x": 0, "y": 0 },
        { "matrix": [1, 0], "x": 0, "y": 1 },

        { "matrix": [0, 1], "x": 1, "y": 0 },
        { "matrix": [1, 1], "x": 1, "y": 1 },

        { "matrix": [0, 2], "x": 2, "y": 0 },
        { "matrix": [1, 2], "x": 2, "y": 1 }
      ]
    }
  }
}
